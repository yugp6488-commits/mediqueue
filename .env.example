NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# MongoDB Atlas (server-only). App data lives here; Supabase handles auth only.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/mydb?retryWrites=true&w=majority
MONGODB_URI=
# Optional: database name if not in the URI path
# MONGODB_DB=myapp
